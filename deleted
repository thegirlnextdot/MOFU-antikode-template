        </div>

        <!-- Title (two lines, each with its own mask reveal) -->
        <div class="t2-title" data-editable data-name="Title">
          <div class="t2-title-line" contenteditable="true">Junior Designers in the AI Era:</div>
          <div class="t2-title-line" contenteditable="true">The Evolution of Creative Value</div>
        </div>

