<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MOFU Template</title>

  <!-- DOM → canvas (handles CSS masks via SVG foreignObject) -->
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.13/dist/html-to-image.min.js"></script>
  <!-- mp4-muxer (ESM) — exposed on window for the regular script below -->
  <script type="module">
    try {
      const m = await import('https://cdn.jsdelivr.net/npm/mp4-muxer@5.2.1/+esm');
      window.Mp4Muxer = { Muxer: m.Muxer, ArrayBufferTarget: m.ArrayBufferTarget };
      window.dispatchEvent(new Event('mp4muxer:ready'));
    } catch (e) {
      console.warn('mp4-muxer failed to load', e);
    }
  </script>
  <style>
    @import url('https://fonts.cdnfonts.com/css/proxima-nova-2');

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: #1a1a1a;
      font-family: 'Proxima Nova', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px;
      gap: 24px;
    }

    .workspace {
      display: flex;
      gap: 20px;
      align-items: flex-start;
    }

    /* ---------- Section nav (editing-only, never rendered to output) ---------- */
    .section-nav {
      width: 220px;
      background: #2a2a2a;
      color: white;
      padding: 16px;
      border-radius: 12px;
      font-size: 13px;
      position: sticky;
      top: 24px;
    }

    .section-nav h3 {
      margin-bottom: 12px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #999;
      font-weight: 600;
    }

    .section-nav ul {
      list-style: none;
    }

    .section-nav li {
      padding: 8px 10px;
      border-radius: 6px;
      cursor: pointer;
      margin-bottom: 4px;
      transition: background 0.12s, color 0.12s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-nav li::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #555;
      flex-shrink: 0;
    }

    .section-nav li:hover {
      background: #3a3a3a;
    }

    .section-nav li.is-active {
      background: #66B2FF;
      color: black;
      font-weight: 600;
    }

    .section-nav li.is-active::before {
      background: black;
    }

    .section-nav .nav-hint {
      margin-top: 14px;
      font-size: 11px;
      color: #888;
      line-height: 1.5;
    }

    /* Highlight + selection treatment on the template elements */
    .editable.is-highlighted {
      outline: 2px solid #B1EF42 !important;
      outline-offset: 8px;
    }

    .editable.is-selected {
      outline: 2px dashed #66B2FF !important;
      outline-offset: 6px;
    }

    .editable.is-selected>.edit-handle {
      opacity: 1;
      pointer-events: auto;
    }

    /* ---------- Control panel ---------- */
    .controls {
      width: 540px;
      background: #2a2a2a;
      color: white;
      padding: 20px;
      border-radius: 12px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      font-size: 13px;
    }

    .controls label {
      display: flex;
      flex-direction: column;
      gap: 6px;
      cursor: pointer;
    }

    .controls .full {
      grid-column: 1 / -1;
    }

    .controls input[type="file"],
    .controls input[type="number"],
    .controls button {
      background: #3a3a3a;
      color: white;
      border: 1px solid #555;
      padding: 8px;
      border-radius: 6px;
      font-family: inherit;
      font-size: 12px;
      cursor: pointer;
    }

    .controls button:hover {
      background: #4a4a4a;
    }

    .controls .hint {
      color: #999;
      font-size: 11px;
    }

    .controls .row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
    }

    /* Template switcher tabs */
    .template-tabs {
      grid-column: 1 / -1;
      display: flex;
      gap: 8px;
    }

    .template-tabs button {
      flex: 1;
      padding: 10px 8px;
    }

    .template-tabs button.is-active {
      background: #B1EF42;
      color: black;
      border-color: #B1EF42;
      font-weight: 600;
    }

    /* ---------- Stage wrappers ---------- */
    .stage {
      position: relative;
      overflow: hidden;
      background: black;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    }

    .stage-1 {
      width: 540px;
      height: 960px;
    }

    .stage-1 .template {
      transform: scale(0.5);
      transform-origin: top left;
    }

    .stage-2 {
      width: 744px;
      height: 400px;
    }

    /* ---------- Template 1 (1080 x 1920) ---------- */
    .template {
      width: 1080px;
      height: 1920px;
      position: relative;
      background: white;
      overflow: hidden;
    }

    /* Optional grid overlay */
    .template.show-grid::after {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(to right, rgba(177, 239, 66, 0.18) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(177, 239, 66, 0.18) 1px, transparent 1px);
      background-size: var(--grid-size, 10px) var(--grid-size, 10px);
      pointer-events: none;
      z-index: 90;
    }

    /* Background video layer */
    .bg-media {
      width: 1080px;
      height: 1921px;
      left: 0;
      top: 0;
      position: absolute;
      overflow: hidden;
      background: #FF0000;
    }

    .bg-media video,
    .bg-media img.bg-fallback {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      top: 0;
      left: 0;
    }

    /* Bottom black gradient */
    .gradient {
      width: 1080px;
      height: 1118.32px;
      left: 0;
      top: 801.68px;
      position: absolute;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, black 59%);
      pointer-events: none;
    }

    /* Glow ellipses (bottom area) — animated together as a group */
    .t1-glows {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .t1-glow-1 {
      width: 986.81px;
      height: 549.20px;
      left: 601.59px;
      top: 1755.72px;
      position: absolute;
      transform: rotate(141deg);
      transform-origin: top left;
      background: linear-gradient(259deg, rgba(5, 64, 82, 0.50) 24%, rgba(3, 25, 33, 0) 100%);
      filter: blur(107px);
    }

    .t1-glow-2 {
      width: 378.04px;
      height: 689.78px;
      left: 378.46px;
      top: 1862.84px;
      position: absolute;
      transform: rotate(80deg);
      transform-origin: top left;
      opacity: 0.45;
      background: linear-gradient(157deg, rgba(22, 22, 22, 0) 0%, rgba(255, 255, 255, 0.30) 100%);
      filter: blur(84px);
    }

    /* Author photo (green square) */
    .author-photo {
      width: 120.26px;
      height: 120.61px;
      left: 63.89px;
      top: 1578.32px;
      position: absolute;
      background: #B1EF42;
      cursor: pointer;
    }

    /* Inner clip layer: crops the zoomed photo without clipping the edit handles */
    .photo-clip {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }

    .photo-clip img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Author text block */
    .written-by {
      width: 298px;
      height: 16px;
      left: 210px;
      top: 1580px;
      position: absolute;
      opacity: 0.50;
      color: white;
      font-size: 20px;
      font-weight: 400;
      text-transform: uppercase;
      line-height: 20px;
      letter-spacing: 6px;
    }

    .author-name {
      width: 386.583px;
      left: 210px;
      top: 1630px;
      position: absolute;
      color: white;
      font-size: 34px;
      font-weight: 400;
      text-transform: capitalize;
      line-height: 34px;
    }

    .author-role {
      width: 297px;
      left: 210px;
      top: 1680px;
      position: absolute;
      opacity: 0.50;
      color: white;
      font-size: 20px;
      font-weight: 400;
      line-height: 20px;
    }

    /* INSIGHT dot (parent of the label so they animate as a group) */
    .insight-dot {
      width: 13px;
      height: 13px;
      left: 64px;
      top: 1182px;
      position: absolute;
      background: white;
      border-radius: 9999px;
      /* overflow visible so the label child can extend outside the circle */
    }

    /* INSIGHT label — positioned RELATIVE to the dot now */
    .insight-label {
      width: 150px;
      height: 10px;
      left: 28px;
      /* 92 (absolute) - 64 (dot left) */
      top: -3px;
      /* 1179 - 1182 */
      position: absolute;
      color: white;
      font-size: 20px;
      font-weight: 600;
      text-transform: uppercase;
      line-height: 20px;
      letter-spacing: 6px;
    }

    /* Logo (top-left) */
    .logo {
      width: 198.385px;
      height: 28.44px;
      left: 64px;
      top: 150px;
      position: absolute;
    }

    .logo img {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Title + meta block */
    .text-block {
      width: 952.323px;
      height: auto;
      left: 63.67px;
      top: 1244.45px;
      position: absolute;
      display: inline-flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 13px;
      min-width: 200px;
      min-height: 50px;
      max-width: 1080px;
    }

    .title {
      align-self: stretch;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      color: white;
      font-size: 74px;
      font-weight: 400;
      line-height: 81.40px;
      word-wrap: break-word;
    }

    .title-line {
      --reveal: 9999px;
      /* default: fully revealed (no mask cut) */
      --feather: 94px;
      width: fit-content;
      max-width: 100%;
      -webkit-mask-image: linear-gradient(to right,
          black calc(var(--reveal) - var(--feather)),
          transparent var(--reveal));
      mask-image: linear-gradient(to right,
          black calc(var(--reveal) - var(--feather)),
          transparent var(--reveal));
    }

    .meta {
      align-self: stretch;
      opacity: 0.50;
      color: white;
      font-size: 30px;
      font-weight: 400;
      line-height: 39px;
      word-wrap: break-word;
    }

    .meta .topic {
      text-transform: capitalize;
    }

    .meta .dash {
      text-transform: uppercase;
      letter-spacing: 2.10px;
    }

    .meta .read {
      text-transform: lowercase;
    }

    /* Rotated bottom overlay image */
    .overlay-rotated {
      width: 1920px;
      height: 1080px;
      left: 0;
      top: 1920px;
      position: absolute;
      transform: rotate(-90deg);
      transform-origin: top left;
      opacity: 0.10;
      pointer-events: none;
    }

    .overlay-rotated img,
    .overlay-rotated video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* ---------- Template 2 — Insight Card (744 x 400) ---------- */
    .template2 {
      width: 744px;
      height: 400px;
      background: black;
    }

    /* Black panel: slides up from the bottom (4s → 6s). Parents the glows + vertical
       line, and clips them so nothing bleeds over the video strip above. */
    .t2-blackbox {
      /* 2px black borders bleed past the left/right/bottom edges so no background
         leaks through at the fractional-pixel seams. With border-box sizing the
         inner (clip) area stays exactly 744 x 260.05 at the same origin, so
         nothing inside shifts. Top edge has no border — it must reveal the video. */
      width: 748px;
      /* 744 + 2 left + 2 right */
      height: 262.05px;
      /* 260.05 + 2 bottom */
      left: -2px;
      top: 139.95px;
      position: absolute;
      background: black;
      overflow: hidden;
      border-left: 2px solid black;
      border-right: 2px solid black;
      border-bottom: 2px solid black;
    }

    /* Background glow decorations (inside the black box; tops are relative to it) */
    .t2-glow-1 {
      width: 900.64px;
      height: 501.24px;
      left: 0.32px;
      top: 169px;
      /* 308.95 - 139.95 */
      position: absolute;
      transform: rotate(321deg);
      transform-origin: top left;
      background: linear-gradient(259deg, rgba(5, 64, 82, 0.50) 24%, rgba(3, 25, 33, 0) 100%);
      filter: blur(43.57px);
      pointer-events: none;
    }

    .t2-glow-2 {
      width: 345.03px;
      height: 629.54px;
      left: 203.97px;
      top: 532.07px;
      /* 672.02 - 139.95 */
      position: absolute;
      transform: rotate(260deg);
      transform-origin: top left;
      opacity: 0.45;
      background: linear-gradient(157deg, rgba(22, 22, 22, 0) 0%, rgba(255, 255, 255, 0.30) 100%);
      filter: blur(34.21px);
      pointer-events: none;
    }

    /* LinkedIn logo (bottom-left, replaces the old tick line) */
    .t2-linkedin {
      width: 7px;
      height: 50px;
      left: 22.56px;
      top: 323.34px;
      position: absolute;
    }

    .t2-linkedin img {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Author group: fills the black box; counter-translated during the box's slide
       so its contents stay fixed on the canvas while the box edge reveals them */
    .t2-authorgroup {
      position: absolute;
      inset: 0;
    }

    /* Vertical line (line.svg) — child of the black box, so it rides up with it */
    .t2-line {
      width: 1px;
      height: 260.05px;
      left: 50px;
      top: 0;
      /* relative to the black box (was 140 on the canvas) */
      position: absolute;
    }

    .t2-line img {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* INSIGHT vertical group (wrapper so label + dot move together) */
    .t2-insight {
      width: 18px;
      height: 64px;
      left: 16px;
      top: 160px;
      position: absolute;
    }

    .t2-insight-label {
      width: 51.01px;
      height: 15.31px;
      left: 2.2px;
      /* 18.20 - 16 */
      top: 56.66px;
      /* 216.66 - 160 */
      position: absolute;
      transform: rotate(-90deg);
      transform-origin: top left;
      text-align: right;
      color: white;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      line-height: 13px;
      letter-spacing: 1.60px;
    }

    .t2-insight-dot {
      width: 6.44px;
      height: 6.44px;
      left: 5.7px;
      /* 21.70 - 16 */
      top: 57.42px;
      /* visual top after the export's rotation */
      position: absolute;
      background: white;
      border-radius: 9999px;
    }

    /* Title */
    .t2-title {
      width: 616.42px;
      left: 89.14px;
      top: 165.65px;
      position: absolute;
      color: white;
      font-size: 35px;
      font-weight: 400;
      line-height: 38.50px;
      word-wrap: break-word;
    }

    /* Per-line mask reveal (same mechanism as template 1, feather 76px) */
    .t2-title-line {
      --reveal: 9999px;
      /* default: fully revealed (no mask cut) */
      --feather: 76px;
      width: fit-content;
      max-width: 100%;
      -webkit-mask-image: linear-gradient(to right,
          black calc(var(--reveal) - var(--feather)),
          transparent var(--reveal));
      mask-image: linear-gradient(to right,
          black calc(var(--reveal) - var(--feather)),
          transparent var(--reveal));
    }

    /* Topic / read time */
    .t2-meta {
      width: 200px;
      left: 89.33px;
      top: 324px;
      position: absolute;
      opacity: 0.50;
      color: white;
      font-size: 12px;
      font-weight: 400;
      text-transform: capitalize;
      line-height: 15.60px;
      word-wrap: break-word;
    }

    /* Written by block */
    .t2-writtenby {
      width: 80px;
      height: 10px;
      left: 603.57px;
      top: 183.03px;
      /* 322.98 - 139.95 (relative to black box) */
      position: absolute;
      color: #909DA5;
      font-size: 10px;
      font-weight: 400;
      text-transform: uppercase;
      line-height: 10px;
      letter-spacing: 1.60px;
      white-space: nowrap;
    }

    .t2-author {
      width: 50.25px;
      left: 603.57px;
      top: 209.37px;
      /* 349.32 - 139.95 */
      position: absolute;
      color: white;
      font-size: 13px;
      font-weight: 400;
      text-transform: capitalize;
      line-height: 12px;
      white-space: nowrap;
    }

    .t2-role {
      width: 80px;
      height: 10px;
      left: 604px;
      top: 225.05px;
      /* 365 - 139.95 */
      position: absolute;
      color: rgba(255, 255, 255, 0.50);
      font-size: 10px;
      font-weight: 400;
      text-transform: capitalize;
      line-height: 12px;
      white-space: nowrap;
    }

    /* Top media bar (red placeholder → video/image upload target) */
    .t2-media {
      /* fullscreen — bleeds 2px past every edge so the canvas corners are always
         filled with video, no seams (the template clips the overflow) */
      width: 748px;
      height: 404px;
      left: -2px;
      top: -2px;
      position: absolute;
      overflow: hidden;
      background: #FF0000;
    }

    .t2-media video,
    .t2-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      top: 0;
      left: 0;
    }

    /* Author photo (green square) */
    .t2-photo {
      width: 50px;
      height: 50px;
      left: 543.68px;
      top: 184.44px;
      /* 324.39 - 139.95 */
      position: absolute;
      background: #B1EF42;
      cursor: pointer;
    }

    /* Template 2 is shown at 1:1 — shrink the edit handles so they don't swallow small elements */
    .template2 .edit-handle {
      width: 28px;
      height: 28px;
      font-size: 14px;
      border-width: 3px;
    }

    .template2 .move-handle {
      left: -14px;
      top: -14px;
    }

    .template2 .resize-handle {
      right: -14px;
      bottom: -14px;
    }

    /* ---------- Editable system (move + resize handles) ---------- */
    .editable:hover {
      outline: 1px dashed rgba(177, 239, 66, 0.7);
      outline-offset: 6px;
    }

    .edit-handle {
      position: absolute;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      border: 4px solid black;
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.12s;
      display: flex;
      align-items: center;
      justify-content: center;
      color: black;
      font-size: 28px;
      line-height: 1;
      font-weight: 700;
      user-select: none;
    }

    .editable:hover>.edit-handle,
    .edit-handle.is-active {
      opacity: 1;
      pointer-events: auto;
    }

    .edit-handle.move-handle {
      background: #66B2FF;
      left: -28px;
      top: -28px;
      cursor: move;
    }

    .edit-handle.resize-handle {
      background: #B1EF42;
      right: -28px;
      bottom: -28px;
      cursor: nwse-resize;
    }

    /* During export: kill ALL editing chrome so none of it can end up in the video —
       selection/hover/highlight outlines, text-editing focus ring, grid, handles */
    .template.is-exporting .editable,
    .template.is-exporting .editable:hover,
    .template.is-exporting .editable.is-selected,
    .template.is-exporting .editable.is-highlighted {
      outline: none !important;
    }

    .template.is-exporting [contenteditable="true"]:focus {
      box-shadow: none !important;
    }

    .template.is-exporting .edit-handle {
      display: none !important;
    }

    .template.is-exporting.show-grid::after {
      display: none !important;
    }

    /* Live coordinate / size readout */
    .live-readout {
      position: fixed;
      background: #B1EF42;
      color: black;
      font-family: ui-monospace, Menlo, Consolas, monospace;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 8px;
      border-radius: 4px;
      pointer-events: none;
      z-index: 9999;
      display: none;
    }

    .live-readout.is-visible {
      display: block;
    }

    /* Editable text (contenteditable) styling */
    [contenteditable="true"] {
      outline: none;
    }

    [contenteditable="true"]:focus {
      box-shadow: inset 0 0 0 2px #B1EF42;
    }

    /* ---------- Timeline panel ---------- */
    .timeline-panel {
      width: 780px;
      background: #2a2a2a;
      color: white;
      padding: 16px 20px;
      border-radius: 12px;
      font-size: 13px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .timeline-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .timeline-panel button {
      background: #3a3a3a;
      color: white;
      border: 1px solid #555;
      padding: 8px 14px;
      border-radius: 6px;
      font-family: inherit;
      font-size: 13px;
      cursor: pointer;
    }

    .timeline-panel button:hover {
      background: #4a4a4a;
    }

    .timeline-panel button.is-active {
      background: #B1EF42;
      color: black;
      border-color: #B1EF42;
    }

    .frame-display {
      font-family: ui-monospace, Menlo, Consolas, monospace;
      color: #B1EF42;
      margin-left: auto;
    }

    #timeline {
      width: 100%;
      -webkit-appearance: none;
      height: 8px;
      background: #1a1a1a;
      border-radius: 4px;
      outline: none;
    }

    #timeline::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      background: #B1EF42;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid black;
    }

    #timeline::-moz-range-thumb {
      width: 18px;
      height: 18px;
      background: #B1EF42;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid black;
    }

    .timeline-hint {
      color: #888;
      font-size: 11px;
    }
  </style>
</head>

<body>

  <div class="controls">
    <div class="template-tabs">
