            <div class="t2-role" data-editable data-name="Author role" contenteditable="true">Sr. UI/UX Designer</div>
            <div class="t2-photo" id="t2Photo" data-editable data-lock-aspect="true" data-name="Author photo"
              title="Click: upload photo · Scroll: zoom · Ctrl+drag: reposition crop">
